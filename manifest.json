{
  "manifest_version": 3,
  "name": "Song ID",
  "version": "3.5",

  "description": "Music recognition. Like shazam or soundhound.",
  "homepage_url": "https://github.com/losnappas/Song-identifier",
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "background": {
    "service_worker": "background/inject.js"
  },

  "action": {
    "default_title": "Identify",
    "default_icon": "icons/icon.svg"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://*.acrcloud.com/v1/identify"
  ],

  "options_ui": {
    "page": "options/options.html"
  }
}
